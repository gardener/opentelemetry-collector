FROM otel/opentelemetry-collector-builder:0.155.0 AS build-stage

USER root
WORKDIR /src
COPY . /src

RUN mkdir -p /build/_out \
 && ocb --config=/src/extension/sdnotify/testdata/manifest.yaml \
 && test -x /build/_out/otelcol

FROM ghcr.io/fauust/docker-systemd:debian-13 AS run-stage

COPY --from=build-stage /build/_out/otelcol /bin/otelcol

# Invalid config: the traces pipeline references an exporter that isn't
# declared under `exporters:`, so the collector exits nonzero at load time
# and systemd never sees READY=1.
COPY extension/sdnotify/testdata/otelcol-invalid-config.yaml /etc/otelcol/config.yaml

# Shared systemd unit: Type=notify. Because the collector exits before
# sending READY=1, systemd's Restart=on-failure loop hits the start-limit
# burst and the unit ends up in a persistent failed state (which is what
# the test polls for via `systemctl is-failed`).
COPY extension/sdnotify/testdata/otelcol.service /etc/systemd/system/otelcol.service
RUN ln -s /etc/systemd/system/otelcol.service /etc/systemd/system/multi-user.target.wants/otelcol.service

ENV container=docker
STOPSIGNAL SIGRTMIN+3

CMD ["/lib/systemd/systemd"]
