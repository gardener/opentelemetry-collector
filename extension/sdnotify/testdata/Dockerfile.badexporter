FROM golang:1.26.2 AS build-stage

ARG OCB_VERSION=v0.155.0
RUN go install go.opentelemetry.io/collector/cmd/builder@${OCB_VERSION} && \
    mv /go/bin/builder /usr/local/bin/ocb

WORKDIR /src
COPY . /src

RUN mkdir -p /build/_out \
 && ocb --config=/src/extension/sdnotify/testdata/manifest.yaml \
 && test -x /build/_out/otelcol

FROM debian:12 AS run-stage

RUN apt-get update \
 && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        systemd systemd-sysv procps ca-certificates

COPY --from=build-stage /build/_out/otelcol /bin/otelcol

# Inline collector config: healthy pipeline plumbing but the OTLP exporter
# is pointed at a port with nothing listening. The exporter starts fine
# (it queues + retries), the collector reaches steady state, and sdnotify
# sends READY=1. This proves the extension does not gate READY=1 on
# downstream/exporter health.
RUN mkdir -p /etc/otelcol && cat <<'EOF' > /etc/otelcol/config.yaml
extensions:
  sdnotify:

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 127.0.0.1:4317

exporters:
  otlp/nonexistent:
    endpoint: 127.0.0.1:65535

service:
  extensions: [sdnotify]
  pipelines:
    traces:
      receivers: [otlp]
      exporters: [otlp/nonexistent]
EOF

# Shared systemd unit: same Type=notify shape as the happy path — we expect
# the unit to reach active despite the unreachable exporter target.
COPY extension/sdnotify/testdata/otelcol.service /etc/systemd/system/otelcol.service
RUN ln -s /etc/systemd/system/otelcol.service /etc/systemd/system/multi-user.target.wants/otelcol.service

ENV container=docker
STOPSIGNAL SIGRTMIN+3

CMD ["/lib/systemd/systemd"]
