[Unit]
Description=OpenTelemetry Collector (sdnotify integration test)
After=network-online.target
Wants=network-online.target

[Service]
Type=notify-reload
NotifyAccess=main
ExecStart=/bin/otelcol --config=/etc/otelcol/config.yaml
TimeoutStartSec=60
Restart=on-failure

[Install]
WantedBy=multi-user.target
